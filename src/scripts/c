#!/usr/bin/env bash
set -eo pipefail

# c - Claude Code wrapper.
#
# - Loads the dotfiles plugin (for /dotfiles:dotfiles-healthcheck etc.)
# - `--resume <id>` / `-r <id>` searches all projects for the conversation
#   and launches claude from the correct working directory. Accepts UUIDs
#   (or prefixes), conversation names (customTitle / agentName), or worktree
#   names (cd into the worktree and show the resume picker).
#
# All other usage is passed through to claude unchanged.

DOTFILES_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd -P)"

find_conversation() {
    local id_prefix="$1"
    local projects_dir="$HOME/.claude/projects"
    local -a matches=()

    # Try matching by file name (UUID prefix)
    for jsonl in "$projects_dir"/*/"${id_prefix}"*.jsonl; do
        [[ -e $jsonl ]] || continue
        local dir full_id
        dir=$(basename "$(dirname "$jsonl")")
        full_id=$(basename "$jsonl" .jsonl)
        matches+=("$dir:$full_id")
    done

    # If no file match, try matching by conversation name (customTitle/agentName)
    if [[ ${#matches[@]} -eq 0 ]]; then
        local jsonl
        while IFS= read -r jsonl; do
            [[ -n $jsonl ]] || continue
            local dir full_id
            dir=$(basename "$(dirname "$jsonl")")
            full_id=$(basename "$jsonl" .jsonl)
            matches+=("$dir:$full_id")
        done < <(
            {
                grep -Fl "\"customTitle\":\"${id_prefix}\"" "$projects_dir"/*/*.jsonl
                grep -Fl "\"agentName\":\"${id_prefix}\"" "$projects_dir"/*/*.jsonl
            } 2>/dev/null | sort -u
        )
    fi

    case ${#matches[@]} in
    0) return 1 ;;
    1) echo "${matches[0]}" ;;
    *)
        echo "c: multiple conversations match '$id_prefix':" >&2
        for m in "${matches[@]}"; do
            echo "  ${m#*:}  (${m%%:*})" >&2
        done
        return 2
        ;;
    esac
}

# Decode a Claude Code project directory name back to a filesystem path.
# Claude encodes paths by replacing / and . with -, so we try all three
# possibilities at each dash and prune via filesystem existence checks.
decode_project_dir() {
    python3 -c '
import os, sys

def decode(encoded):
    s = encoded.lstrip("-")
    return _try(s, 0, "/")

def _try(s, pos, path):
    if pos >= len(s):
        return path if os.path.exists(path) else None
    dash = s.find("-", pos)
    if dash == -1:
        final = path + s[pos:]
        return final if os.path.exists(final) else None
    seg = s[pos:dash]
    if seg == "":
        # Consecutive dashes: original was /. or /- (try . first)
        for ch in (".", "-"):
            r = _try(s, dash + 1, path + ch)
            if r is not None:
                return r
        return None
    # Try / (only if path + seg is an existing directory)
    test = path + seg
    if os.path.isdir(test):
        r = _try(s, dash + 1, test + "/")
        if r is not None:
            return r
    # Try .
    r = _try(s, dash + 1, path + seg + ".")
    if r is not None:
        return r
    # Try literal -
    r = _try(s, dash + 1, path + seg + "-")
    if r is not None:
        return r
    return None

result = decode(sys.argv[1])
if result:
    print(result)
    sys.exit(0)
sys.exit(1)
' "$1"
}

main() {
    local resume_id=""
    local -a other_args=()
    local intercepting=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
        --resume=* | -r=*)
            resume_id="${1#*=}"
            intercepting=true
            shift
            ;;
        --resume | -r)
            if [[ $# -gt 1 && $2 != -* ]]; then
                resume_id="$2"
                intercepting=true
                shift 2
            else
                # No ID (interactive picker) - pass through
                other_args+=("$1")
                shift
            fi
            ;;
        *)
            other_args+=("$1")
            shift
            ;;
        esac
    done

    if ! $intercepting; then
        exec claude --plugin-dir "$DOTFILES_DIR" "${other_args[@]}"
    fi

    local match find_rc=0
    match=$(find_conversation "$resume_id") || find_rc=$?

    if [[ $find_rc -eq 0 ]]; then
        # Found by UUID or conversation name - resume specific session
        local project_dir="${match%%:*}"
        local full_id="${match#*:}"

        local real_path
        if ! real_path=$(decode_project_dir "$project_dir"); then
            echo "c: could not resolve directory for project '$project_dir'" >&2
            echo "c: falling back to current directory" >&2
            exec claude --plugin-dir "$DOTFILES_DIR" --resume "$full_id" "${other_args[@]}"
        fi

        echo "c: resuming in $real_path" >&2
        cd "$real_path"
        exec claude --plugin-dir "$DOTFILES_DIR" --resume "$full_id" "${other_args[@]}"
    fi

    # Not found as conversation — try as worktree name
    if [[ $find_rc -eq 1 ]]; then
        local toplevel
        toplevel=$(git rev-parse --show-toplevel 2>/dev/null) || true
        if [[ -n $toplevel && -d "$toplevel/.claude/worktrees/$resume_id" ]]; then
            echo "c: resuming in $toplevel/.claude/worktrees/$resume_id" >&2
            cd "$toplevel/.claude/worktrees/$resume_id"
            exec claude --plugin-dir "$DOTFILES_DIR" --resume "${other_args[@]}"
        fi
        echo "c: '$resume_id' not found as conversation, name, or worktree" >&2
    fi
    # find_rc=2: multiple matches (error already printed by find_conversation)
    exit 1
}

main "$@"
